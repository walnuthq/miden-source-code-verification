{
  "name": "miden-source-code-verification-api-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --conditions development src/server.ts",
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "exports": {
    "./app": {
      "types": "./dist/src/app.d.ts",
      "default": "./dist/src/app.js"
    },
    "./db": {
      "types": "./dist/src/db/index.d.ts",
      "default": "./dist/src/db/index.js"
    }
  },
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "express": "5.2.1",
    "miden-source-code-verification-utils": "workspace:*",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "7.2.0",
    "drizzle-kit": "1.0.0-rc.4",
    "miden-source-code-verification-test-utils": "workspace:*",
    "supertest": "7.2.2",
    "tsc-alias": "1.9.0",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
