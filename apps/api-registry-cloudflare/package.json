{
  "name": "miden-source-code-verification-api-registry-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm --filter miden-source-code-verification-api-registry build && tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "cf:typegen": "wrangler types",
    "cf:dev": "pnpm --filter miden-source-code-verification-api-registry build && wrangler dev --port 8081",
    "cf:deploy": "pnpm --filter miden-source-code-verification-api-registry build && wrangler deploy"
  },
  "dependencies": {
    "miden-source-code-verification-api-registry": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "typescript": "6.0.3",
    "wrangler": "4.106.0"
  }
}
